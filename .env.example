# ─── Бэкенд (backend/.env) ────────────────────────────────────────────────
#
# Подключение к БД. Railway подставит автоматически при добавлении PostgreSQL-плагина.
# Локально: SQLite
DATABASE_URL=sqlite:///./quiz_face.db

# Разрешённые источники CORS (через запятую)
CORS_ORIGINS=http://localhost:5173

# Путь к папке с загружаемыми файлами
UPLOADS_DIR=../uploads

# Порог схожести лиц (0.0–1.0; меньше = строже)
FACE_TOLERANCE=0.5

# Модель детектирования: hog (CPU) | cnn (GPU/CUDA)
FACE_DETECTION_MODEL=hog


# ─── Фронтенд (frontend/.env) ─────────────────────────────────────────────
#
# Базовый URL бэкенда. Пусто → Vite-proxy перехватывает запросы локально.
# На Railway: https://<имя-сервиса>.up.railway.app
VITE_API_URL=
